{
  "manifest_version": 3,
  "name": "AccessAI — RL Accessibility Personaliser",
  "version": "1.0.0",
  "description": "CT-469 P15: Applies RL-personalised accessibility settings (font, contrast, colour scheme) to any website using a trained LinUCB contextual bandit agent.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
